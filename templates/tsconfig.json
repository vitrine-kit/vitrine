    "backend-payload/files/lib/seed/demo.ts",
    "backend-payload/files/lib/seed/guards.ts",
    "backend-vendure/files/lib/adapter/vendure-types.ts",
    "backend-vendure/files/lib/adapter/map.ts"
  ]
}
