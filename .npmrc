# @vitrine-kit/* packages are published to the public npm (registry.npmjs.org).
# The registry is public — no auth is needed for install (neither locally nor in CI/docker).
# Publishing happens from CI (setup-node + NODE_AUTH_TOKEN=NPM_TOKEN), see .github/workflows/release.yml.
# Inside the monorepo, packages are linked via workspace:* — the registry is not involved.

# pnpm
auto-install-peers=true
strict-peer-dependencies=false
