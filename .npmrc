# Пакеты @vitrine-kit/* публикуются в публичный npm (registry.npmjs.org).
# Реестр публичный — авторизация для install НЕ нужна (ни локально, ни в CI/docker).
# Публикация идёт из CI (setup-node + NODE_AUTH_TOKEN=NPM_TOKEN), см. .github/workflows/release.yml.
# Внутри монорепо пакеты линкуются через workspace:* — реестр не задействован.

# pnpm
auto-install-peers=true
strict-peer-dependencies=false
