# Приватные пакеты Vitrine публикуются/ставятся через GitHub Packages.
# Scope @maks417 совпадает с владельцем github.com/Maks417 (требование GitHub Packages).
@maks417:registry=https://npm.pkg.github.com

# pnpm
auto-install-peers=true
strict-peer-dependencies=false

# Авторизация НЕ коммитится. Токен задаётся в окружении:
#   - CI: setup-node с registry-url + NODE_AUTH_TOKEN, либо строка
#         //npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
#   - локально для установки приватных @maks417/* в клиентских репо:
#         положить ту же строку в ~/.npmrc с личным PAT (scope read:packages).
# В самом монорепо kit внутренние пакеты идут через workspace:* — токен для install не нужен.
