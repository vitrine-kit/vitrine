{
  "name": "@maks417/payload-blueprint",
  "version": "0.0.0",
  "description": "Vitrine — базовые Payload-коллекции + аддитивный extend().",
  "license": "UNLICENSED",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maks417/vitrine.git",
    "directory": "packages/payload-blueprint"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@maks417/contracts": "workspace:*"
  }
}
